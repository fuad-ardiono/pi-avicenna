{
  "name": "pi-avicenna",
  "version": "0.1.0",
  "description": "Pi Avicenna orchestration skills and delegation extension for Pi.",
  "private": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "assets",
    "dist/src",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-avicenna"
  ],
  "pi": {
    "extensions": [
      "./assets/extensions/subagent.ts"
    ],
    "skills": [
      "./assets/skills"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "pack": "npm pack --dry-run",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
